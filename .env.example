# ─── Required ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# 12-word BIP-39 seed phrase — this controls the WDK wallet
WDK_SEED=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# ─── Telegram ────────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the bot
# Find yours by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=123456789

# ─── Web Terminal ────────────────────────────────────────────────────────────
WEB_PORT=3000
# Optional: set this to require a token for web terminal access
WEB_ACCESS_TOKEN=

# ─── Arbitrum RPC (defaults to public endpoint — set for reliability) ────────
ETH_RPC_URL=https://arb1.arbitrum.io/rpc
# Alternative: Alchemy/Infura for higher rate limits
# ETH_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── WDK Optional ────────────────────────────────────────────────────────────
WDK_INDEXER_API_KEY=
# ERC-4337 Account Abstraction — set to enable gasless txs via a bundler
WDK_USE_ERC4337=false
# Free public Pimlico bundler for Arbitrum One (no API key needed for testing)
WDK_BUNDLER_URL=https://public.pimlico.io/v2/42161/rpc
# For production, use your own Pimlico key:
# WDK_BUNDLER_URL=https://api.pimlico.io/v2/arbitrum/rpc?apikey=YOUR_KEY

# ─── AI Models (defaults are fine) ───────────────────────────────────────────
OPENAI_MODEL_ROUTING=gpt-4o-mini
OPENAI_MODEL_REASONING=gpt-4o

# ─── x402 Payment Protocol ───────────────────────────────────────────────────
# Address that receives autonomous micropayments for premium market intel
# Set to your WDK wallet address (get it by running: npm run dev, then /health)
PREMIUM_SERVICE_ADDRESS=0x...your_wallet_address

# ─── NexusGuard On-Chain Risk Parameters ─────────────────────────────────────
# Address of the deployed NexusGuard contract on Arbitrum
# Deploy with: ./scripts/deploy-guard.sh (requires DEPLOYER_PRIVATE_KEY)
NEXUS_GUARD_ADDRESS=0xCe5DfFba0AFa9f671b92F891F1B93C4986A64DaD
# Private key for deploying NexusGuard — only needed once for deployment
# Remove from .env after deployment
DEPLOYER_PRIVATE_KEY=0x...
# Optional: Arbiscan API key for contract verification
ARBISCAN_API_KEY=
